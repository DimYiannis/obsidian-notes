		{"id":"t6","fromNode":"switch","fromSide":"right","toNode":"router","toSide":"left","label":"between → router"},
		{"id":"t7","fromNode":"router","fromSide":"right","toNode":"gateway","toSide":"left","label":"reached via"},
		{"id":"t8","fromNode":"router","fromSide":"bottom","toNode":"route","toSide":"top","label":"uses"},
